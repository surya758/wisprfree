#!/bin/sh
# Enforce Conventional Commits on the summary line.
# Enable once per clone with:  git config core.hooksPath .githooks
# (install.sh does this automatically.)

summary=$(grep -vE '^\s*#' "$1" | sed '/./,$!d' | head -n1)

# Allow merge/revert/fixup commits to pass through untouched.
case "$summary" in
  "Merge "*|"Revert "*|"fixup!"*|"squash!"*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?!?: .+'

if printf '%s' "$summary" | grep -Eq "$pattern"; then
  exit 0
fi

cat >&2 <<'EOF'
✗ Commit message must follow Conventional Commits.

  <type>(optional-scope): <description>

  types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
  examples:
    feat(history): click a row to copy it
    fix(dictionary): trim trailing whitespace
    chore: bump version to 0.1.2

EOF
exit 1
